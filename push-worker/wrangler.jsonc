{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "planorha-push-worker",
  "main": "src/index.js",
  "compatibility_date": "2026-07-17",
  "compatibility_flags": ["nodejs_compat"],
  "triggers": {
    "crons": ["* * * * *"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "planorha-db",
      "database_id": "REEMPLAZAR_CON_DATABASE_ID"
    }
  ]
}
